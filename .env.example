# KD-IRIS 환경변수 템플릿 (KwangDong Integrated Regulatory Intelligence System)
# 사용법:
#   1) cp .env.example .env
#   2) .env 파일에 실제 키 입력 (data.go.kr 마이페이지에서 발급)
#   3) python -m drug_integrated_search.run 으로 서버 재시작
# .env 는 git 에 커밋되지 않음 (.gitignore 등록 완료)

# ============================================================================
# 공공데이터포털 (data.go.kr) — 18개 API 공통 인증키
# 발급: https://www.data.go.kr 마이페이지 > 개발계정
# 활용기간: 2026-05-26 ~ 2028-05-26 (2년)
# ============================================================================
PUBLIC_DATA_SERVICE_KEY=

# ============================================================================
# 식품안전나라 (foodsafetykorea.go.kr) — NO 339 등 식품 API 별도 인증키
# 발급: https://www.foodsafetykorea.go.kr/api/userApiKey.do
# 미발급 시 빈 값 유지 — 해당 API만 비활성화됨
# ============================================================================
FOODSAFETY_KEY_ID=

# ============================================================================
# Flask 설정
# ============================================================================
FLASK_SECRET_KEY=change-this-to-random-32-char-string-in-production
FLASK_DEBUG=False

# ============================================================================
# 네트워크 / SSL
# ============================================================================
# Windows 사내망 SSL 인증서 문제 발생 시 False
VERIFY_SSL=False

# ============================================================================
# 데이터 동기화 (Phase 2 이후)
# ============================================================================
DAILY_BATCH_HOUR=3
CACHE_TTL_SECONDS=3600

# ============================================================================
# PostgreSQL (Phase 2 이후)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/reghub360

# ============================================================================
# Redis (Phase 2 이후)
# ============================================================================
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# 알림 채널 (Phase 2 이후)
# ============================================================================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# SLACK_WEBHOOK_URL=
# KAKAOWORK_WEBHOOK_URL=

# ============================================================================
# MISO 에이전트 (Phase 2 이후, AI 자연어 검색 F-006)
# ============================================================================
# MISO_API_BASE=
# MISO_API_KEY=
